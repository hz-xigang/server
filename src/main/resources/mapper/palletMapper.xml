<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gz.xg.mapper.PalletMapper">

    <select id="tagExitsByTagNo" resultType="java.lang.String">
        SELECT top 1 tagNo FROM [palletTag] WHERE tagNo = #{tagNo}
    </select>

    <select id="tagExitsByTagNos" resultType="java.lang.String">
        SELECT tagNo FROM  [palletTag] WHERE tagNo IN
        <foreach collection="tagNos"
                 item="tagNo"
                 open="("
                 close=")"
                 separator=",">
            #{tagNo}
        </foreach>

    </select>
</mapper>